# Copy this file to `.env`. It holds only non-secret config (PROVIDER, MODEL);
#
#   cp .env.example .env
#
# Your API key is NOT stored here or in .env — see the "API keys" note lower
# down and ../SECRETS.md. (.env is in .gitignore regardless; never commit it.)

# ---------------------------------------------------------------------------
# Prompt engineering is provider-agnostic — pick whichever you already have.
#
#   openai  -> OpenAI chat        (needs OPENAI_API_KEY)
#   claude  -> Claude messages    (needs ANTHROPIC_API_KEY)
#
# Default is "openai".
# ---------------------------------------------------------------------------
PROVIDER=openai

# --- API keys are NOT stored here ---
# Your key never goes in this file or in .env. Store it in your OS keychain and
# inject it per-command with `secrun` (2-minute setup: ../SECRETS.md), then run
# key-using scripts as:  secrun python examples/...
#   PROVIDER=openai  needs  OPENAI_API_KEY     https://platform.openai.com/api-keys
#   PROVIDER=claude  needs  ANTHROPIC_API_KEY  https://console.anthropic.com/settings/keys

# --- Optional: override the chat model for the active stack ---
# Defaults: gpt-4o-mini (openai) / claude-haiku-4-5 (claude).
# MODEL=gpt-4o

# --- Optional: a dedicated reasoning model for fundamentals/14 ---
# REASONING_MODEL=o4-mini

# ---------------------------------------------------------------------------
# Run a LOCAL model instead (Ollama, LM Studio, llama.cpp, vLLM).
# Local servers speak the OpenAI API, so keep PROVIDER=openai and point the
# base URL at the local endpoint. Any non-empty key works.
#
#   PROVIDER=openai
#   OPENAI_API_KEY=local
#   OPENAI_BASE_URL=http://localhost:11434/v1   # Ollama (LM Studio :1234, llama.cpp :8080, vLLM :8000)
#   MODEL=llama3.1
# ---------------------------------------------------------------------------
# OPENAI_BASE_URL=
